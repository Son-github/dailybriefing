# 로컬 Docker 전용 값이다. 이 파일을 .env.local로 복사하고 실제 값을 입력한다.
POSTGRES_DB=dashboard
POSTGRES_USER=sonny
POSTGRES_PASSWORD=change-me

JWT_SECRET=change-me-at-least-32-bytes-long
JWT_ACCESS_VALIDITY_MS=3600000
JWT_REFRESH_VALIDITY_MS=604800000

EXCHANGE_API_KEY=
WEATHER_API_KEY=

# 선택한 지수 제공자가 있을 때만 입력한다.
KIS_APP_KEY=
KIS_APP_SECRET=
TWELVE_DATA_API_KEY=
US_MARKET_SYMBOL=IXIC
